  "keyFeatures": [
    "Hexagonal/modular architecture with decoupled, scalable code",
    "ACID transactions with automatic rollback on failures",
    "Strict validation using DTOs and class-validator",
    "Optimized QueryBuilder for efficient SQL queries",
    "Swagger OpenAPI documentation",
    "Complete CRUD operations with pagination and soft delete",
    "Serverless architecture with AWS Lambda support"
  ],
  "publicApiSurface": [
    "POST /api/campaigns - Create campaign with messages",
    "POST /api/clients - Create client",
    "GET /api/clients - List clients (paginated)",
    "GET /api/clients/:id - Get client details",
    "PATCH /api/clients/:id - Update client",
    "DELETE /api/clients/:id - Soft delete client",
    "POST /api/users - Create user",
    "GET /api/users - List users (paginated)",
    "GET /api/users/:id - Get user details",
    "PATCH /api/users/:id - Update user",
    "DELETE /api/users/:id - Soft delete user",
    "GET /api/reports/dashboard - Get messages by status report"
  ]
}
